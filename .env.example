# ─────────────────────────────────────────────────────────────────────────────
# HUB RW Meta Hub — exemplo de configuração
#
# Copie para `.env` e preencha. TODOS os valores de credencial podem, em vez
# disso, ser informados pelo painel em /  (aba "Configuração do App").
# O painel grava em data/settings.json e tem PRIORIDADE sobre estas variáveis.
# Nenhuma credencial é embutida no código — este projeto nasce vazio.
# ─────────────────────────────────────────────────────────────────────────────

# Porta HTTP (padrão: 3300)
PORT=3300

# URL pública deste hub, SEM barra no final.
# É a base usada nos redirect_uri do OAuth e na URL de webhook mostrada no painel.
# Ex.: https://hub.rwsolucoesdigitais.com
PUBLIC_URL=https://hub.rwsolucoesdigitais.com

# Nome de marca exibido no painel. Vazio = "HUB RW".
BRAND_NAME=HUB RW

# Storage persistente. Vazio = arquivos JSON locais em data/.
# Para Vercel/produção serverless, use PostgreSQL.
# Ex.: postgresql://usuario:senha@host:5432/banco?sslmode=disable
DATABASE_URL=

# Máximo de conexões por instância serverless. Mantenha baixo para PostgreSQL self-hosted.
PG_POOL_MAX=3

# ─── Segurança ───────────────────────────────────────────────────────────────

# Segredo HMAC usado para: assinar o "state" do OAuth, os tokens de sessão do
# painel e validar a assinatura dos webhooks. Gere com: openssl rand -hex 32
# Se ficar vazio, um segredo aleatório é gerado a cada boot (sessões e fluxos
# OAuth em andamento quebram a cada restart — defina em produção).
SESSION_SECRET=

# Senha do painel admin. Se vazia, o painel abre SEM autenticação (apenas dev).
# Defina em produção.
ADMIN_PASSWORD=

# ─── Multi-app ───────────────────────────────────────────────────────────────
# Este hub gerencia VÁRIOS apps Meta pelo painel (aba "Apps"), cada um com suas
# credenciais, URL de webhook (/webhook/app/<id>) e destinos de encaminhamento.
#
# As variáveis META_* abaixo são OPCIONAIS: servem apenas para "semear" UM app
# automaticamente no primeiro boot (deploys headless) — só rodam se META_APP_ID
# estiver preenchido E ainda não existir nenhum app. Depois disso, gerencie tudo
# pelo painel. O App Secret NUNCA é exposto ao navegador.

# Versão padrão da Graph API usada ao criar apps (ex.: v23.0).
META_API_VERSION=v23.0

# Timeout (ms) ao encaminhar webhooks para os destinos. Padrão: 10000.
FORWARD_TIMEOUT_MS=10000

# --- Seed opcional de um app no primeiro boot ---
META_APP_NAME=App principal
META_APP_ID=
META_APP_SECRET=
META_WABA_CONFIG_ID=
META_MESSENGER_CONFIG_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
WEBHOOK_VERIFY_TOKEN=

# ─── Webhook ─────────────────────────────────────────────────────────────────

# Quantidade máxima de eventos de webhook mantidos em memória/disco (ring).
# Padrão: 500.
WEBHOOK_EVENTS_MAX=500

# Logar no console cada webhook recebido (1/true/yes/on). Padrão: off.
WEBHOOK_DEBUG_LOG=
